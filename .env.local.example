# ============================================
# ICONOS Panel — Variables de entorno
# Copia este archivo a .env.local y llena los valores
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- ClickUp ---
# API key: ClickUp → tu avatar → Apps → API Token → Generate
CLICKUP_API_KEY=

# Workspace ID: lo ves en la URL de ClickUp (app.clickup.com/<workspace_id>/...)
CLICKUP_WORKSPACE_ID=

# Space "ICONOS ADMIN" — donde van las cotizaciones (board "Cotizaciones")
# y las tareas Admin de Johana.
# Las cotizaciones se crean SIEMPRE en el sprint vigente; la lista se resuelve
# automáticamente cada mes buscando el folder de sprint activo y dentro la
# lista "Cotizaciones".
CLICKUP_SPACE_ICONOS_ADMIN=

# Space "ICONOS CU" (ICONOS ClickUp) — para tareas de desarrollo (Fase 2).
CLICKUP_SPACE_ICONOS_CU=

# Opcional: override manual de la lista de cotizaciones. Solo úsalo si quieres
# fijar una lista específica (ej. para pruebas). En producción déjalo vacío y
# se resuelve dinámicamente desde CLICKUP_SPACE_ICONOS_ADMIN.
CLICKUP_LIST_COTIZACIONES_ID=

# Opcional: User ID por defecto para asignar tickets de cotización (Johana).
# Si no se pone, el sistema busca un miembro cuyo username contenga "johana".
CLICKUP_DEFAULT_ASSIGNEE_ID=

# --- Slack ---
# Bot User OAuth Token (xoxb-...) de la app de Slack
SLACK_BOT_TOKEN=
# Signing Secret (para verificar webhooks de Slack)
SLACK_SIGNING_SECRET=
# Channel ID del canal admin (right-click en el canal en Slack → "Copy link"
# → el último segmento de la URL, ej. C0123ABCDEF).
SLACK_CHANNEL_ADMIN=
# User ID de Sherlyn (perfil → ··· → "Copy member ID", ej. U012AB3CDE).
SLACK_USER_SHERLYN_ID=

# --- JIRA ---
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# --- Clockify ---
CLOCKIFY_API_KEY=
CLOCKIFY_WORKSPACE_ID=

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- Web Push (VAPID) ---
# Genera con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ia@iconos.mx

# --- Auth admin ---
# Hash bcrypt de la contraseña, codificado en base64 (Next.js expande los $ si están literales).
# Genera con:
# node -e "console.log(Buffer.from(require('bcryptjs').hashSync('TU_PASSWORD', 10)).toString('base64'))"
ADMIN_PASSWORD_HASH=
SESSION_SECRET=
